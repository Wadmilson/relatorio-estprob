lambda <- 0.02
x <- 100
lx <- lambda * x   # 0,02 * 100 = 2
probabilidade <- 1 - exp(-lx) * (1 + lx + (lx^2)/2)
probabilidade
cat("Probabilidade =", round(probabilidade, 4), "ou", round(probabilidade * 100, 2), "%")
lambda <- 0.02   # taxa média de falhas por hora
r <- 3           # número de falhas desejadas
x <- 100         # tempo limite em horas
# Cálculo exato conforme a fórmula da Distribuição Gama apresentada
probabilidade <- 1 - exp(-lambda * x) * (1 + lambda * x + (lambda * x)^2 / 2)
# Resultado
probabilidade
cat("Probabilidade de ocorrer até", r, "falhas em", x, "horas =", round(probabilidade * 100, 2), "%\n")
# Parâmetros
lambda <- 0.02
r <- 3
theta <- 1 / lambda
x <- 100
# Cálculo da probabilidade
probabilidade <- pgamma(q = x, shape = r, scale = theta)
# Resultado
cat("Probabilidade =", round(probabilidade * 100, 2), "%")
p <- 0.25    # probabilidade de sucesso
k <- 5       # tentativa desejada
# Cálculo pela fórmula
probabilidade <- (1 - p)^(k - 1) * p
# Ou usando a função própria da distribuição geométrica
probabilidade_funcao <- dgeom(x = k - 1, prob = p)
# Resultado
cat("Probabilidade de o primeiro sucesso ocorrer na 5ª tentativa =", round(probabilidade * 100, 2), "%\n")
cat("Pela função dgeom(): =", round(probabilidade_funcao * 100, 2), "%\n")
