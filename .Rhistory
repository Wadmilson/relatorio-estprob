p <- 0.25          # probabilidade de sucesso
k <- 5             # 5ª tentativa
# Cálculo da probabilidade
prob_geo <- (1 - p)^(k - 1) * p
# Resultado
cat("Probabilidade =", round(prob_geo * 100, 2), "%\n")
